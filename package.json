{
  "name": "passcontrol",
  "version": "0.1.0",
  "private": true,
  "description": "Secure Agent Control Plane & Passport Vault — identity-aware reverse proxy for AI agent credentials.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "migrate": "bash scripts/migrate.sh",
    "dev:stack": "bash scripts/dev-stack.sh",
    "dev:docker": "bash -c 'set -a; . ./.env.docker; set +a; next dev'",
    "seed": "node scripts/seed.mjs",
    "sidecar": "node examples/visa-sidecar.mjs",
    "test:rls": "psql -v ON_ERROR_STOP=1 -f db/tests/rls_invariants.sql \"$DATABASE_URL\"",
    "prepare": "git config core.hooksPath .githooks || true"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@noble/curves": "^1.6.0",
    "@noble/hashes": "^1.5.0",
    "@sentry/nextjs": "^10.64.0",
    "@supabase/ssr": "^0.5.1",
    "@supabase/supabase-js": "^2.45.4",
    "@upstash/redis": "^1.34.0",
    "@vercel/functions": "^1.4.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jose": "^5.9.3",
    "lucide-react": "^1.20.0",
    "next": "^15.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^22.5.5",
    "@types/react": "^18.3.8",
    "@types/react-dom": "^18.3.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.6.2",
    "vitest": "^4.1.9"
  }
}
