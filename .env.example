# ── Supabase ────────────────────────────────────────────────────────────────
# Public (browser) values:
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ey...
# Service role — server/edge only. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=ey...

# ── Visa (Scoped Access JWT) signing ─────────────────────────────────────────
# 32+ byte random secrets. VISA_SECRET_PREV enables zero-downtime rotation.
VISA_SECRET=replace-with-32+byte-random-string
VISA_SECRET_PREV=
VISA_TTL_SECONDS=300

# ── Provider-key cache encryption (Tension 1) ────────────────────────────────
# base64-encoded 32-byte (256-bit) AES key. Generate: openssl rand -base64 32
CACHE_ENC_KEY=

# ── Upstash Redis (REST) ─────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://YOUR-DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# (Kill switch is Redis-backed — no extra Vercel services / API tokens needed.)

# ── Proxy per-agent request-rate limit (call-volume guard; budget is separate) ─
# Max proxied calls per agent per window. Generous default; tune for your fleet.
PROXY_RATE_LIMIT=600
PROXY_RATE_WINDOW_S=60

# ── Control-plane API (optional; sensible defaults if unset) ─────────────────
# Pre-auth per-IP flood guard on /api/control/v1 (requests per minute).
CONTROL_IP_LIMIT=1000

# ── Kill switch (optional) ───────────────────────────────────────────────────
# If a kill-switch Redis read fails, the default is to fail OPEN (don't block) —
# the same Redis backs budgets/suspend, so an outage already fails requests. Set
# this to "true" to fail CLOSED instead (a read failure blocks all traffic). Off
# by default. Strict operators who want the emergency stop to never pass through
# on error should enable it.
KILL_SWITCH_FAIL_CLOSED=false

# ── Cron auth ────────────────────────────────────────────────────────────────
CRON_SECRET=replace-with-random-string
# Reconcile settle-lag: only fold agent_logs rows older than this (seconds) so a
# row can't be skipped between its insert and the reconcile snapshot. Optional.
RECONCILE_LAG_SECONDS=60

# ── Security alerting (optional) ─────────────────────────────────────────────
# Incoming-webhook URL for real-time alerts on high-signal security events
# (account lockout, rate-limit trip, master kill switch, agent suspend). Works
# with a free Slack OR Discord incoming webhook. Leave blank to disable (events
# are still logged). Vercel Log Drains are the paid alternative.
SECURITY_ALERT_WEBHOOK=

# ── Error tracking / observability (optional) ────────────────────────────────
# Optional Sentry DSN for scrubbed error + high-signal security-event capture.
# Leave blank to disable. The app strips request/response bodies, auth headers,
# cookies, visas, passport keys, provider keys, API keys, and service secrets
# before sending anything to Sentry.
SENTRY_DSN=

# ── Dashboard signup gate ────────────────────────────────────────────────────
# Anyone signing up must enter this exact code. Keeps strangers from creating
# accounts in front of your provider keys. Share it only with people you trust.
INVITE_CODE=replace-with-a-shared-invite-code
