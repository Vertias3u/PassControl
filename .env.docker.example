# Local Docker stack env — template. `scripts/dev-stack.sh` generates the live
# `.env.docker` from this by filling the Supabase keys from `supabase status` and
# generating fresh secrets. Committed as a reference; the generated `.env.docker`
# is gitignored. These are LOCAL DEV values only — never real secrets.

# ── Supabase (local CLI stack: `supabase start`) ─────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<from: supabase status -o env (ANON_KEY)>
SUPABASE_SERVICE_ROLE_KEY=<from: supabase status -o env (SERVICE_ROLE_KEY)>

# ── Redis over REST (docker/compose.yml: redis + serverless-redis-http) ───────
UPSTASH_REDIS_REST_URL=http://localhost:8079
UPSTASH_REDIS_REST_TOKEN=passcontrol_local_dev_token

# ── Secrets (dev-stack.sh generates random values) ───────────────────────────
VISA_SECRET=<generated: 32+ random bytes>
VISA_TTL_SECONDS=300
CACHE_ENC_KEY=<generated: openssl rand -base64 32>
CRON_SECRET=<generated>

# ── Dashboard signup gate ────────────────────────────────────────────────────
INVITE_CODE=local-dev

# ── Seed user (scripts/seed.mjs) ─────────────────────────────────────────────
DEV_USER_EMAIL=dev@passcontrol.local
DEV_USER_PASSWORD=passcontrol-dev

# ── Demo mode ────────────────────────────────────────────────────────────────
# Set to 1 to enable the keyless `demo` provider + seed a demo passport, so a
# stranger can run `passcontrol try` (governed call + kill switch, no real key).
# OFF by default; production must never enable it. Bring the stack up with:
#   PASSCONTROL_DEMO=1 npm run dev:stack  &&  PASSCONTROL_DEMO=1 npm run dev:docker
PASSCONTROL_DEMO=0
